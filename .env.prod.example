DOMAIN=idbjovemeteen.tech

# ---------- FastAPI ----------
ENVIRONMENT=producao
APP_PORT=8000
DEBUG=False
SECRET_KEY=TROQUE_POR_UMA_CHAVE_ALEATORIA_FORTE

BASE_URL=https://api.idbjovemeteen.tech

CORS_ORIGINS=https://idbjovemeteen.tech,https://www.idbjovemeteen.tech

# ---------- Banco de Dados (Postgres no proprio Docker da VPS) ----------
POSTGRES_USER=idbjovem
POSTGRES_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE
POSTGRES_DB=idb_jovem
DATABASE_URL=postgresql://idbjovem:TROQUE_POR_UMA_SENHA_FORTE@db:5432/idb_jovem

# ---------- Google OAuth ----------
GOOGLE_CLIENT_ID="seu-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="seu-client-secret"
GOOGLE_REDIRECT_URI="https://api.idbjovemeteen.tech/auth/callback"
GOOGLE_REFRESH_TOKEN="seu-refresh-token"

# ---------- Keycloak ----------
KEYCLOAK_URL=https://auth.idbjovemeteen.tech
KEYCLOAK_REALM=jovem
KEYCLOAK_CLIENT_ID=jovem-backend
KEYCLOAK_ISSUER=https://auth.idbjovemeteen.tech/realms/jovem
KEYCLOAK_JWKS_URL=http://keycloak:8080/realms/jovem/protocol/openid-connect/certs
KEYCLOAK_AUDIENCE=account
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE
